# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zendvo

# ─── Auth ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_strong_random_secret

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/zendvo
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Stellar / Soroban ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
# mainnet horizon: https://horizon.stellar.org
# testnet horizon: https://horizon-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_ESCROW_CONTRACT_ID=replace_with_deployed_contract_id
# Server-side signing key (never expose to client)
STELLAR_SERVER_SECRET_KEY=replace_with_stellar_secret_key

# ─── USDC ──────────────────────────────────────────────────────────────────────
# Testnet USDC issuer
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ASSET_CODE=USDC

# ─── Payments ──────────────────────────────────────────────────────────────────
# Paystack (NGN on/off-ramp)
PAYSTACK_SECRET_KEY=replace_with_paystack_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key

# Stripe (international cards)
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# ─── SMS / OTP ─────────────────────────────────────────────────────────────────
TERMII_API_KEY=replace_with_termii_api_key
TERMII_SENDER_ID=Zendvo

# ─── Cron ──────────────────────────────────────────────────────────────────────
# Secret sent as "Authorization: Bearer <CRON_SECRET>" by Vercel Cron / external scheduler
# Add this value to GitHub Actions secrets and Vercel environment variables
CRON_SECRET=replace_with_a_strong_random_secret

# ─── Redis (job queue / caching) ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudinary (gift media uploads) ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# ─── Database Backup (issue #362) ─────────────────────────────────────────────
# S3 bucket name for pg_dump backups (set via Terraform output backup_bucket_name)
BACKUP_S3_BUCKET=lumigift-prod-db-backups
# AWS region where the backup bucket lives
AWS_REGION=us-east-1
