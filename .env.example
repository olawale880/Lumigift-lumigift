# ─── App ───────────────────────────────────────────────────────────────────────

# [REQUIRED] Base URL where the app is hosted (used for redirects, webhooks, etc.)
# Format: Full URL with protocol (http:// or https://)
# Local dev: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] Application display name shown in UI and notifications
# Format: Plain text string
NEXT_PUBLIC_APP_NAME=Lumigift

# ─── Auth ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Canonical URL for NextAuth.js (must match NEXT_PUBLIC_APP_URL)
# Format: Full URL with protocol
# Used by NextAuth for callback URLs and session management
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] Secret key for signing and encrypting JWT tokens and session cookies
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: Random string, minimum 32 characters recommended
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_strong_random_secret

# [OPTIONAL] Previous secret key used during key rotation
# Key rotation: set to the OLD secret when rotating NEXTAUTH_SECRET.
# Old tokens remain valid for NEXTAUTH_ROTATION_GRACE_HOURS (default 24).
# Remove NEXTAUTH_SECRET_PREVIOUS after the grace period expires.
# Format: Same as NEXTAUTH_SECRET
NEXTAUTH_SECRET_PREVIOUS=

# [OPTIONAL] Grace period in hours for accepting tokens signed with old secret
# Default: 24 hours if not specified
# Format: Integer (hours)
NEXTAUTH_ROTATION_GRACE_HOURS=24

# CSRF token signing secret — generate with: openssl rand -hex 32
CSRF_SECRET=replace_with_a_strong_random_secret

# ─── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# ⚠️  WARNING: Never commit real credentials! Use environment-specific values.
# Format: postgresql://username:password@host:port/database
# Local dev: postgresql://user:password@localhost:5432/lumigift
# Production: Use managed database URL (e.g., from Vercel Postgres, Supabase, AWS RDS)
DATABASE_URL=postgresql://user:password@localhost:5432/lumigift

# [OPTIONAL] Minimum number of connections in the pool
# Default: 2 if not specified
# Format: Integer
DB_POOL_MIN=2

# [OPTIONAL] Maximum number of connections in the pool
# Default: 10 if not specified
# Format: Integer (adjust based on database plan limits)
DB_POOL_MAX=10

# [OPTIONAL] Time in milliseconds before idle connections are closed
# Default: 10000 (10 seconds) if not specified
# Format: Integer (milliseconds)
DB_IDLE_TIMEOUT_MS=10000

# [OPTIONAL] Time in milliseconds to wait for a connection before timing out
# Default: 5000 (5 seconds) if not specified
# Format: Integer (milliseconds)
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Stellar / Soroban ─────────────────────────────────────────────────────────

# [REQUIRED] Stellar network to use (testnet or mainnet)
# Format: "testnet" or "mainnet"
# Use testnet for development, mainnet for production
STELLAR_NETWORK=testnet

# [REQUIRED] Stellar Horizon API endpoint for blockchain queries
# Format: Full HTTPS URL
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
# Obtain from: https://developers.stellar.org/docs/data/horizon
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# [REQUIRED] Network passphrase for transaction signing
# Format: Exact string matching the network
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
# Obtain from: https://developers.stellar.org/docs/learn/fundamentals/networks
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# [REQUIRED] Deployed Soroban escrow contract address
# Format: Contract ID starting with 'C' (e.g., CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM)
# Obtain by: Deploy contract using scripts/deploy-contract.ts
STELLAR_ESCROW_CONTRACT_ID=replace_with_deployed_contract_id

# [REQUIRED] Server-side Stellar secret key for signing transactions
# ⚠️  CRITICAL: Never expose to client! Never commit real values!
# Format: Stellar secret key starting with 'S' (e.g., SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX)
# Obtain from: Create account at https://laboratory.stellar.org/#account-creator (testnet)
# Or use: stellar-cli keys generate --network testnet
# Production: Store in AWS Secrets Manager or HashiCorp Vault — see docs/ops/key-rotation.md
# Rotation: Follow docs/ops/key-rotation.md; new key takes effect on next deployment with no downtime
STELLAR_SERVER_SECRET_KEY=replace_with_stellar_secret_key

# [REQUIRED] Soroban RPC endpoint for smart contract calls and event indexing
# Format: Full HTTPS URL
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-rpc.stellar.org
# Obtain from: https://developers.stellar.org/docs/data/rpc
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# [REQUIRED] Server public key derived from STELLAR_SERVER_SECRET_KEY
# Format: Stellar public key starting with 'G' (e.g., GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX)
# Obtain by: Derive from secret key using stellar-cli or Stellar SDK
# Used for: RPC simulations and transaction verification
STELLAR_SERVER_PUBLIC_KEY=replace_with_stellar_public_key

# ─── USDC ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Stellar account that issues USDC tokens
# Format: Stellar public key starting with 'G'
# Testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
# Obtain from: https://developers.circle.com/stablecoins/docs/usdc-on-stellar
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# [REQUIRED] Asset code for USDC on Stellar
# Format: String, typically "USDC"
# Should always be: USDC
USDC_ASSET_CODE=USDC

# ─── Payments ──────────────────────────────────────────────────────────────────

# Paystack (NGN on/off-ramp for Nigerian payments)

# [REQUIRED] Paystack secret key for server-side API calls
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: String starting with 'sk_test_' (test) or 'sk_live_' (production)
# Obtain from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=replace_with_paystack_secret_key

# [REQUIRED] Paystack public key for client-side payment initialization
# Format: String starting with 'pk_test_' (test) or 'pk_live_' (production)
# Obtain from: https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=replace_with_paystack_public_key

# Stripe (international card payments)

# [REQUIRED] Stripe secret key for server-side API calls
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: String starting with 'sk_test_' (test) or 'sk_live_' (production)
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=replace_with_stripe_secret_key

# [REQUIRED] Stripe publishable key for client-side payment forms
# Format: String starting with 'pk_test_' (test) or 'pk_live_' (production)
# Obtain from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key

# [REQUIRED] Stripe webhook signing secret for verifying webhook events
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: String starting with 'whsec_'
# Obtain from: https://dashboard.stripe.com/webhooks (after creating webhook endpoint)
# Webhook URL should be: {NEXT_PUBLIC_APP_URL}/api/v1/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# ─── SMS / OTP ─────────────────────────────────────────────────────────────────

# [REQUIRED] Termii API key for sending SMS OTP codes
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: String (API key from Termii dashboard)
# Obtain from: https://accounts.termii.com/#/api-settings
TERMII_API_KEY=replace_with_termii_api_key

# [REQUIRED] Sender ID shown in SMS messages
# Format: String, max 11 characters (alphanumeric)
# Must be registered and approved in Termii dashboard
# Obtain from: https://accounts.termii.com/#/sender-id
TERMII_SENDER_ID=Lumigift

# ─── Cron ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret for authenticating cron job requests
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: Random string, minimum 32 characters recommended
# Generate with: openssl rand -base64 32
# Used as: Authorization header "Bearer <CRON_SECRET>" by Vercel Cron / external scheduler
# Add this value to: GitHub Actions secrets and Vercel environment variables
CRON_SECRET=replace_with_a_strong_random_secret

# ─── Redis (job queue / caching) ───────────────────────────────────────────────
# Standalone mode (default)
# Format: redis://[username:password@]host:port[/database]
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Sentinel mode (for High Availability)
REDIS_USE_SENTINEL=false
REDIS_SENTINEL_HOSTS=localhost:26379,localhost:26380,localhost:26381
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINEL_PASSWORD=


# ─── Gift Amount Limits (AML / regulatory) ─────────────────────────────────────

# [OPTIONAL] Minimum gift amount in Nigerian Naira
# Default: 500 if not specified
# Format: Integer (NGN, no decimals)
# Used for: AML compliance and preventing micro-transaction spam
GIFT_MIN_AMOUNT_NGN=500

# [OPTIONAL] Maximum single gift amount in Nigerian Naira
# Default: 500000 if not specified
# Format: Integer (NGN, no decimals)
# Used for: AML compliance and regulatory limits
GIFT_MAX_AMOUNT_NGN=500000

# [OPTIONAL] Maximum total gift amount per user per day in Nigerian Naira
# Default: 1000000 if not specified
# Format: Integer (NGN, no decimals)
# Used for: AML compliance and fraud prevention
GIFT_DAILY_LIMIT_NGN=1000000

# ─── Cloudinary (gift media uploads) ──────────────────────────────────────────

# [REQUIRED] Cloudinary cloud name for media storage
# Format: String (your cloud name)
# Obtain from: https://console.cloudinary.com/console (Dashboard > Account Details)
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name

# [REQUIRED] Cloudinary API key for authentication
# Format: Numeric string
# Obtain from: https://console.cloudinary.com/console (Dashboard > Account Details)
CLOUDINARY_API_KEY=replace_with_api_key

# [REQUIRED] Cloudinary API secret for server-side operations
# ⚠️  WARNING: Never commit real values! Keep this secret secure.
# Format: Alphanumeric string
# Obtain from: https://console.cloudinary.com/console (Dashboard > Account Details)
CLOUDINARY_API_SECRET=replace_with_api_secret

# ─── Sentry (error monitoring) ─────────────────────────────────────────────────
# DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=replace_with_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=replace_with_sentry_dsn
# Required for source-map uploads during CI/CD
SENTRY_ORG=replace_with_sentry_org_slug
SENTRY_PROJECT=replace_with_sentry_project_slug
SENTRY_AUTH_TOKEN=replace_with_sentry_auth_token
