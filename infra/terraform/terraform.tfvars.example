# Copy to terraform.tfvars and fill in real values.
# Never commit terraform.tfvars — it is gitignored.

aws_region         = "us-east-1"
env                = "prod"
vpc_id             = "vpc-xxxxxxxxxxxxxxxxx"
private_subnet_ids = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-yyyyyyyyyyyyyyyyy"]
db_instance_class  = "db.t4g.micro"
# db_password — set via TF_VAR_db_password environment variable, not here
redis_node_type    = "cache.t4g.micro"
app_image          = "123456789012.dkr.ecr.us-east-1.amazonaws.com/lumigift:latest"
domain_name        = "lumigift.app"
