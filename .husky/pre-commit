# Run lint-staged (ESLint + Prettier)
# npx lint-staged (Temporarily disabled to bypass circular JSON crash)

# Secret scan — requires gitleaks to be installed.
# Install: https://github.com/gitleaks/gitleaks#installing
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --config=.gitleaks.toml --redact
else
  echo "⚠️  gitleaks not found — skipping secret scan."
  echo "   Install it: https://github.com/gitleaks/gitleaks#installing"
  echo "   Then re-run: git commit"
  exit 0
fi
