{
  "name": "lumigift",
  "version": "0.1.0",
  "private": false,
  "description": "A full-stack gifting platform on Stellar — send time-locked cash gifts that unlock on a surprise date.",
  "keywords": [
    "stellar",
    "soroban",
    "gifting",
    "blockchain",
    "usdc",
    "nextjs",
    "typescript"
  ],
  "homepage": "https://www.lumigift.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/JosephOnuh/Lumigift-lumigift.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern='integration\\.test\\.ts$' --testEnvironment=node --passWithNoTests",
    "mutation": "stryker run",
    "contract:build": "cd contracts && stellar contract build",
    "contract:test": "cd contracts && cargo test",
    "contract:deploy": "ts-node scripts/deploy-contract.ts",
    "contract:bindings": "npm run contract:build && ts-node scripts/generate-bindings.ts",
    "license:check": "license-checker --production --failOn 'GPL;AGPL;LGPL;GPL-2.0;GPL-3.0;AGPL-3.0;LGPL-2.0;LGPL-2.1;LGPL-3.0' --excludePrivatePackages",
    "e2e": "playwright test",
    "db:migrate": "node-pg-migrate up",
    "db:rollback": "node-pg-migrate down",
    "db:seed:test": "ts-node scripts/seed-test-db.ts",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "docker:up": "docker-compose up",
    "docker:up:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "docker:logs": "docker-compose logs -f",
    "worker:stellar": "ts-node src/server/queue-worker.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.530.0",
    "@growthbook/growthbook-react": "^1.6.5",
    "@hookform/resolvers": "^5.4.0",
    "@react-pdf/renderer": "^4.3.0",
    "@sentry/nextjs": "10.54.0",
    "@stellar/stellar-sdk": "^15.1.0",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "bullmq": "^5.78.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "next": "16.2.7",
    "next-auth": "^4.24.14",
    "pg": "^8.21.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "playwright": "^1.60.0",
    "posthog-js": "1.378.1",
    "react": "^19.2.7",
    "react-hook-form": "^7.77.0",
    "redis": "^6.0.0",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/nextjs": "^8.6.12",
    "@storybook/react": "^8.6.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "chromatic": "^17.2.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.11",
    "jest": "^30.4.2",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.4.1",
    "license-checker": "25.0.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "react-dom": "^19.2.6",
    "storybook": "^8.6.12",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
