# ─── Staging Environment Variables ───────────────────────────────────────────
# Copy to .env.staging and fill in values before running docker-compose.staging.yml
# ⚠️  Never commit real values. Use test-mode keys for all payment providers.

STAGING_APP_URL=https://staging.lumigift.app

# Auth
STAGING_NEXTAUTH_SECRET=replace_with_strong_random_secret

# Database (separate staging DB)
STAGING_DB_PASSWORD=replace_with_staging_db_password

# Stellar — testnet only
STAGING_STELLAR_ESCROW_CONTRACT_ID=replace_with_testnet_contract_id
STAGING_STELLAR_SERVER_SECRET_KEY=replace_with_testnet_secret_key
STAGING_STELLAR_SERVER_PUBLIC_KEY=replace_with_testnet_public_key

# Payments — test mode keys
STAGING_PAYSTACK_SECRET_KEY=sk_test_replace_with_paystack_test_key
STAGING_NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_with_paystack_test_key
STAGING_STRIPE_SECRET_KEY=sk_test_replace_with_stripe_test_key
STAGING_NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_stripe_test_key
STAGING_STRIPE_WEBHOOK_SECRET=whsec_replace_with_stripe_test_webhook_secret

# SMS
STAGING_TERMII_API_KEY=replace_with_termii_api_key

# Cron
STAGING_CRON_SECRET=replace_with_strong_random_secret

# Sentry (optional for staging)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
